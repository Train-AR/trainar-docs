---
import type { DocCategory } from '../lib/supabase';
import { getIcon } from '../lib/icons';

export interface Props {
  category: DocCategory;
  pageCount: number;
}

const { category, pageCount } = Astro.props;
const Icon = getIcon(category.icon);
---

<a
  href={`/${category.slug}`}
  class="group block rounded-xl border border-slate-200 bg-white p-5 shadow-sm hover:shadow-md hover:border-slate-300 transition"
>
  <div class="flex items-start gap-4">
    <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-blue-50 text-blue-600 group-hover:bg-blue-100 transition">
      <Icon class="h-5 w-5" />
    </span>
    <div class="min-w-0 flex-1">
      <h3 class="text-base font-semibold text-slate-900 group-hover:text-blue-700 transition">{category.name}</h3>
      <p class="mt-1 text-sm text-slate-600 line-clamp-2">{category.description}</p>
      <p class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-slate-500">
        <span>{pageCount} {pageCount === 1 ? 'page' : 'pages'}</span>
        <span class="text-slate-300">·</span>
        <span class="text-blue-600 group-hover:underline">Browse →</span>
      </p>
    </div>
  </div>
</a>
