---
import type { DocCategory } from '../lib/supabase';
import { getIcon } from '../lib/icons';

export interface Props {
  category: DocCategory;
  pageCount: number;
}

const { category, pageCount } = Astro.props;
const Icon = getIcon(category.icon);
---

<a
  href={`/${category.slug}`}
  class="group relative block rounded-2xl border border-[#E2E8F0] bg-white p-6 shadow-[0_1px_2px_hsla(228,29%,10%,0.05)] hover:shadow-[0_4px_20px_hsla(212,100%,50%,0.15)] hover:border-[#8FBEFF] transition-all duration-200"
>
  <div class="flex items-start gap-4">
    <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-[#E8F2FF] to-[#C8DEFF] text-[#0074FF] group-hover:from-[#0074FF] group-hover:to-[#0066DD] group-hover:text-white transition-all duration-200">
      <Icon class="h-5 w-5" />
    </span>
    <div class="min-w-0 flex-1">
      <h3 class="text-base font-bold tracking-tight text-[#121621]">{category.name}</h3>
      <p class="mt-1 text-sm text-[#4B5563] line-clamp-2 leading-relaxed">{category.description}</p>
      <div class="mt-4 flex items-center gap-1.5 text-xs font-semibold text-[#6B7280]">
        <span class="uppercase tracking-wider">{pageCount} {pageCount === 1 ? 'page' : 'pages'}</span>
        <span class="text-[#CBD5E1]">·</span>
        <span class="text-[#0074FF] group-hover:underline underline-offset-2">Browse →</span>
      </div>
    </div>
  </div>
</a>
