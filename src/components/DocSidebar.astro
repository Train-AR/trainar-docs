---
import type { DocCategory, DocPage } from '../lib/supabase';
import { getIcon } from '../lib/icons';

export interface Props {
  categories: DocCategory[];
  pagesByCategory: Map<string, DocPage[]>;
  activeCategorySlug?: string;
  activePageSlug?: string;
}

const { categories, pagesByCategory, activeCategorySlug, activePageSlug } = Astro.props;
---

<aside class="hidden lg:block w-64 shrink-0 border-r border-[#E2E8F0] bg-gradient-to-b from-white to-[#F8FAFC]">
  <nav class="sticky top-16 max-h-[calc(100vh-4rem)] overflow-y-auto p-4">
    <ul class="space-y-0.5">
      {categories.map((cat) => {
        const Icon = getIcon(cat.icon);
        const pages = pagesByCategory.get(cat.id) ?? [];
        const isActive = activeCategorySlug === cat.slug;
        return (
          <li>
            <a
              href={`/${cat.slug}`}
              class={`group flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition ${isActive ? 'bg-gradient-to-br from-[#E8F2FF] to-[hsla(212,100%,50%,0.08)] text-[#0052B3] font-semibold' : 'text-[#374151] hover:bg-[#F1F5F9]'}`}
            >
              <Icon class={`w-[18px] h-[18px] ${isActive ? 'text-[#0074FF]' : 'text-[#6B7280] group-hover:text-[#374151]'}`} />
              <span class="truncate">{cat.name}</span>
            </a>
            {isActive && pages.length > 0 && (
              <ul class="ml-7 mt-1 mb-2 space-y-0.5 border-l-2 border-[#C8DEFF] pl-3">
                {pages.map((p) => (
                  <li>
                    <a
                      href={`/${cat.slug}/${p.slug}`}
                      class={`block rounded-md px-2.5 py-1.5 text-[13px] transition ${activePageSlug === p.slug ? 'text-[#0074FF] font-semibold bg-[#E8F2FF]' : 'text-[#4B5563] hover:text-[#121621] hover:bg-[#F1F5F9]'}`}
                    >
                      {p.title}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        );
      })}
    </ul>
  </nav>
</aside>
