---
import Layout from '../../layouts/Layout.astro';
import DocSidebar from '../../components/DocSidebar.astro';
import MobileNav from '../../components/MobileNav.astro';
import { fetchCategories, fetchPublishedPages, type DocCategory, type DocPage } from '../../lib/supabase';
import { getIcon } from '../../lib/icons';

export async function getStaticPaths() {
  const [categories, pages] = await Promise.all([fetchCategories(), fetchPublishedPages()]);
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: {
      category: cat,
      pages: pages.filter((p) => p.category_id === cat.id),
      allCategories: categories,
      allPages: pages,
    },
  }));
}

interface Props {
  category: DocCategory;
  pages: DocPage[];
  allCategories: DocCategory[];
  allPages: DocPage[];
}

const { category, pages, allCategories, allPages } = Astro.props;
const Icon = getIcon(category.icon);

// Per-page logo overrides — surfaces an inline brand mark on category index rows
const pageLogos: Record<string, string> = {
  'integrations/servicem8-integration': '/integrations/servicem8-logo.png',
  'integrations/servicem8-setup-guide': '/integrations/servicem8-logo.png',
  'integrations/jobber': '/integrations/jobber-logo.png',
  'integrations/commusoft': '/integrations/commusoft-logo.png',
  'integrations/simpro': '/integrations/simpro-logo.png',
  'integrations/zapier': '/integrations/zapier-logo.png',
  'integrations/n8n': '/integrations/n8n-logo.svg',
  'marketplace/parts-and-spares': '/integrations/parts-arena-logo.png',
};
const logoFor = (pageSlug: string) => pageLogos[`${category.slug}/${pageSlug}`] ?? null;

const pagesByCategory = new Map<string, DocPage[]>();
for (const p of allPages) {
  if (!pagesByCategory.has(p.category_id)) pagesByCategory.set(p.category_id, []);
  pagesByCategory.get(p.category_id)!.push(p);
}
---

<Layout
  title={`${category.name} — TrainAR Docs`}
  description={category.description ?? `Documentation for ${category.name} in TrainAR.`}
  canonicalPath={`/${category.slug}`}
>
  <MobileNav
    categories={allCategories}
    pagesByCategory={pagesByCategory}
    activeCategorySlug={category.slug}
  />
  <div class="mx-auto max-w-7xl flex">
    <DocSidebar
      categories={allCategories}
      pagesByCategory={pagesByCategory}
      activeCategorySlug={category.slug}
    />

    <div class="flex-1 px-4 sm:px-6 lg:px-10 py-12">
      <div class="max-w-4xl">
        <nav class="mb-6 flex items-center gap-2 text-sm text-[#6B7280]">
          <a href="/" class="hover:text-[#0074FF] transition">Docs</a>
          <span class="text-[#CBD5E1]">/</span>
          <span class="text-[#121621] font-medium">{category.name}</span>
        </nav>

        <div class="mb-10 flex items-start gap-5">
          <span class="inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-[#E8F2FF] to-[#C8DEFF] text-[#0074FF] shadow-[0_4px_20px_hsla(212,100%,50%,0.15)]">
            <Icon class="h-7 w-7" />
          </span>
          <div>
            <h1 class="font-[var(--font-display)] text-4xl sm:text-5xl font-bold tracking-tight text-[#121621] uppercase leading-[1.05]">{category.name}</h1>
            <p class="mt-3 text-lg text-[#4B5563] leading-relaxed">{category.description}</p>
          </div>
        </div>

        <ul class="divide-y divide-[#E2E8F0] rounded-2xl border border-[#E2E8F0] bg-white shadow-[0_1px_2px_hsla(228,29%,10%,0.05)] overflow-hidden">
          {pages.map((p) => {
            const logo = logoFor(p.slug);
            return (
              <li>
                <a
                  href={`/${category.slug}/${p.slug}`}
                  class="block px-6 py-5 hover:bg-[#F8FAFC] transition group"
                >
                  <div class="flex items-start gap-4">
                    {logo && (
                      <span class="shrink-0 inline-flex h-12 w-12 items-center justify-center rounded-lg border border-[#E2E8F0] bg-white">
                        <img src={logo} alt="" class="max-h-9 max-w-9 object-contain" />
                      </span>
                    )}
                    <div class="flex-1 min-w-0">
                      <div class="flex items-baseline justify-between gap-4">
                        <span class="text-base font-semibold text-[#121621] group-hover:text-[#0074FF] transition">{p.title}</span>
                        <span class="text-xs uppercase tracking-wider font-medium text-[#9CA3AF] shrink-0">Updated {new Date(p.updated_at).toLocaleDateString('en-GB', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                      </div>
                      {p.excerpt && <p class="mt-1.5 text-sm text-[#4B5563] line-clamp-2 leading-relaxed">{p.excerpt}</p>}
                    </div>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </div>
</Layout>
