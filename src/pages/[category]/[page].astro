---
import Layout from '../../layouts/Layout.astro';
import DocSidebar from '../../components/DocSidebar.astro';
import MobileNav from '../../components/MobileNav.astro';
import FeedbackWidget from '../../components/FeedbackWidget.astro';
import { fetchCategories, fetchPublishedPages, type DocCategory, type DocPage } from '../../lib/supabase';
import { getIcon } from '../../lib/icons';
import { marked } from 'marked';

export async function getStaticPaths() {
  const [categories, pages] = await Promise.all([fetchCategories(), fetchPublishedPages()]);
  const catById = new Map(categories.map((c) => [c.id, c]));
  return pages
    .map((p) => {
      const cat = catById.get(p.category_id);
      if (!cat) return null;
      return {
        params: { category: cat.slug, page: p.slug },
        props: { category: cat, page: p, allCategories: categories, allPages: pages },
      };
    })
    .filter(Boolean);
}

interface Props {
  category: DocCategory;
  page: DocPage;
  allCategories: DocCategory[];
  allPages: DocPage[];
}

const { category, page, allCategories, allPages } = Astro.props;
const Icon = getIcon(category.icon);

const pagesByCategory = new Map<string, DocPage[]>();
for (const p of allPages) {
  if (!pagesByCategory.has(p.category_id)) pagesByCategory.set(p.category_id, []);
  pagesByCategory.get(p.category_id)!.push(p);
}

// reading time
const wordCount = (page.content ?? '').trim().split(/\s+/).length;
const readMinutes = Math.max(1, Math.ceil(wordCount / 220));

// first image as og:image fallback
const firstImage = (page.content ?? '').match(/!\[[^\]]*\]\(([^)]+)\)/);
const ogImage = firstImage?.[1] ?? 'https://docs.trainar.ai/og-default.png';

// render markdown
marked.setOptions({ gfm: true, breaks: false });
const rawHtml = await marked.parse(page.content ?? '');

// GFM-style callouts: blockquotes starting with [!NOTE|TIP|IMPORTANT|WARNING|CAUTION]
const calloutMeta: Record<string, { label: string; icon: string }> = {
  NOTE: { label: 'Note', icon: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  TIP: { label: 'Tip', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },
  IMPORTANT: { label: 'Important', icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.915a1 1 0 00.95-.69l1.519-4.674z' },
  WARNING: { label: 'Warning', icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z' },
  CAUTION: { label: 'Caution', icon: 'M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.502-1.667 1.732-3L13.73 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z' },
};
const html = rawHtml.replace(
  /<blockquote>\s*<p>\[!(NOTE|TIP|IMPORTANT|WARNING|CAUTION)\]\s*(?:<br\s*\/?>)?\s*([\s\S]*?)<\/p>([\s\S]*?)<\/blockquote>/g,
  (_m, kind: string, firstPara: string, rest: string) => {
    const meta = calloutMeta[kind];
    const slug = kind.toLowerCase();
    return `<div class="doc-callout doc-callout-${slug}">` +
      `<div class="doc-callout-header"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="${meta.icon}"/></svg>${meta.label}</div>` +
      `<div class="doc-callout-body">${firstPara ? `<p>${firstPara}</p>` : ''}${rest}</div>` +
      `</div>`;
  },
);

// Extract H2/H3 for table of contents
const toc: Array<{ level: 2 | 3; text: string; id: string }> = [];
const headingMatches = html.matchAll(/<h([23])(?:\s[^>]*)?>([\s\S]*?)<\/h[23]>/g);
for (const m of headingMatches) {
  const level = parseInt(m[1], 10) as 2 | 3;
  const text = m[2].replace(/<[^>]+>/g, '').trim();
  const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  toc.push({ level, text, id });
}
// Inject IDs into the rendered headings so anchor links work
let tocIdx = 0;
const htmlWithIds = html.replace(/<h([23])(\s[^>]*)?>([\s\S]*?)<\/h[23]>/g, (_m, level, attrs = '', inner) => {
  const item = toc[tocIdx++];
  if (!item) return _m;
  return `<h${level} id="${item.id}"${attrs}>${inner}</h${level}>`;
});

const updatedDate = new Date(page.updated_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout
  title={`${page.title} — TrainAR Docs`}
  description={page.excerpt ?? `${page.title} — TrainAR documentation.`}
  canonicalPath={`/${category.slug}/${page.slug}`}
  ogImage={ogImage}
>
  <MobileNav
    categories={allCategories}
    pagesByCategory={pagesByCategory}
    activeCategorySlug={category.slug}
    activePageSlug={page.slug}
  />
  <div class="mx-auto max-w-7xl flex">
    <DocSidebar
      categories={allCategories}
      pagesByCategory={pagesByCategory}
      activeCategorySlug={category.slug}
      activePageSlug={page.slug}
    />

    <div class="flex-1 px-4 sm:px-6 lg:px-10 py-10 min-w-0">
      <div class="flex gap-10">
        <article class="max-w-3xl min-w-0 flex-1">
          <nav class="mb-6 flex items-center gap-2 text-sm text-[#6B7280]">
            <a href="/" class="hover:text-[#0074FF] transition">Docs</a>
            <span class="text-[#CBD5E1]">/</span>
            <a href={`/${category.slug}`} class="hover:text-[#0074FF] transition">{category.name}</a>
            <span class="text-[#CBD5E1]">/</span>
            <span class="text-[#121621] truncate font-medium">{page.title}</span>
          </nav>

          <header class="mb-10">
            <div class="flex items-center gap-2 mb-4 text-sm text-[#6B7280]">
              <Icon class="h-4 w-4 text-[#0074FF]" />
              <a href={`/${category.slug}`} class="font-semibold text-[#374151] hover:text-[#0074FF] transition">{category.name}</a>
              <span class="text-[#CBD5E1]">·</span>
              <span>Last updated {updatedDate}</span>
              <span class="text-[#CBD5E1]">·</span>
              <span>{readMinutes} min read</span>
            </div>
            <h1 class="font-[var(--font-display)] text-4xl sm:text-5xl font-bold tracking-tight text-[#121621] uppercase leading-[1.05]">{page.title}</h1>
            {page.excerpt && <p class="mt-4 text-lg text-[#4B5563] leading-relaxed">{page.excerpt}</p>}
          </header>

          <div class="doc-prose" set:html={htmlWithIds} />

          <FeedbackWidget pageSlug={`${category.slug}/${page.slug}`} pageTitle={page.title} />

          <footer class="mt-12 pt-8 border-t border-[#E2E8F0]">
            <a href={`/${category.slug}`} class="inline-flex items-center gap-2 text-sm font-semibold text-[#4B5563] hover:text-[#0074FF] transition">
              ← Back to {category.name}
            </a>
          </footer>
        </article>

        {toc.length > 1 && (
          <aside class="hidden xl:block flex-shrink-0 w-56">
            <div class="sticky top-24">
              <p class="text-xs font-bold uppercase tracking-widest text-[#0074FF] mb-3">On this page</p>
              <ul class="space-y-2 text-sm border-l border-[#E2E8F0]">
                {toc.map((item) => (
                  <li>
                    <a
                      href={`#${item.id}`}
                      class={item.level === 3
                        ? "block pl-6 -ml-px py-1 text-[#6B7280] hover:text-[#0074FF] hover:border-l-2 hover:border-[#0074FF] transition border-l-2 border-transparent"
                        : "block pl-3 -ml-px py-1 text-[#374151] font-medium hover:text-[#0074FF] hover:border-l-2 hover:border-[#0074FF] transition border-l-2 border-transparent"}
                    >{item.text}</a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )}
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .doc-prose {
    font-family: "Roboto", "Roboto Condensed", -apple-system, system-ui, sans-serif;
    color: #121621;
    line-height: 1.7;
    font-size: 17px;
  }
  .doc-prose h2 {
    font-family: "D-DIN Condensed", "Roboto Condensed", system-ui, sans-serif;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 1.875rem;
    font-weight: 700;
    color: #121621;
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    border-bottom: 2px solid #E2E8F0;
    padding-bottom: 0.6rem;
  }
  .doc-prose h3 {
    font-family: "D-DIN Condensed", "Roboto Condensed", system-ui, sans-serif;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: #121621;
    text-transform: uppercase;
    letter-spacing: -0.005em;
  }
  .doc-prose h4 {
    font-family: "Montserrat", "Inter", system-ui, sans-serif;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: #121621;
  }
  .doc-prose p {
    margin-top: 0.85rem;
    margin-bottom: 0.85rem;
    color: #1F2937;
  }
  .doc-prose ul, .doc-prose ol {
    margin-top: 0.85rem;
    margin-bottom: 0.85rem;
    padding-left: 1.5rem;
  }
  .doc-prose ul { list-style: disc; }
  .doc-prose ol { list-style: decimal; }
  .doc-prose li { margin-top: 0.4rem; padding-left: 0.25rem; color: #1F2937; }
  .doc-prose li::marker { color: #0074FF; }
  .doc-prose li > p { margin: 0.35rem 0; }
  .doc-prose strong { color: #121621; font-weight: 700; }
  .doc-prose a {
    color: #0074FF;
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: #C8DEFF;
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s;
  }
  .doc-prose a:hover {
    color: #0052B3;
    text-decoration-color: #0074FF;
  }
  .doc-prose code {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    background: #F1F5F9;
    color: #0052B3;
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
    font-size: 0.875em;
    font-weight: 500;
    border: 1px solid #E2E8F0;
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  .doc-prose {
    overflow-wrap: anywhere;
    word-wrap: break-word;
  }
  .doc-prose table {
    display: block;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .doc-callout {
    margin: 1.75rem 0;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    border-left: 4px solid;
    background: #F8FAFC;
  }
  .doc-callout-header {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "D-DIN Condensed", "Roboto Condensed", system-ui, sans-serif;
    text-transform: uppercase;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    margin-bottom: 0.4rem;
  }
  .doc-callout-body p:first-child { margin-top: 0; }
  .doc-callout-body p:last-child { margin-bottom: 0; }
  .doc-callout-note { border-left-color: #0074FF; background: #EFF6FF; }
  .doc-callout-note .doc-callout-header { color: #0052B3; }
  .doc-callout-tip { border-left-color: #14B89B; background: #ECFDF5; }
  .doc-callout-tip .doc-callout-header { color: #047857; }
  .doc-callout-important { border-left-color: #8B5CF6; background: #F5F3FF; }
  .doc-callout-important .doc-callout-header { color: #6D28D9; }
  .doc-callout-warning { border-left-color: #F59E0B; background: #FFFBEB; }
  .doc-callout-warning .doc-callout-header { color: #B45309; }
  .doc-callout-caution { border-left-color: #EF4444; background: #FEF2F2; }
  .doc-callout-caution .doc-callout-header { color: #B91C1C; }
  .doc-prose pre {
    background: #121621;
    color: #F1F5F9;
    border-radius: 12px;
    padding: 1.1rem 1.4rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    box-shadow: 0 4px 20px hsla(212, 100%, 50%, 0.10);
  }
  .doc-prose pre code {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    background: transparent;
    color: inherit;
    padding: 0;
    border: 0;
    font-size: inherit;
  }
  .doc-prose img {
    border-radius: 12px;
    border: 1px solid #E2E8F0;
    margin: 2rem auto;
    box-shadow: 0 4px 20px hsla(212, 100%, 50%, 0.08);
    max-width: 100%;
    height: auto;
  }
  .doc-prose .doc-logo-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0.5rem 0 2rem;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    background: #F7FAFC;
    border: 1px solid #E2E8F0;
  }
  .doc-prose .doc-logo-row img {
    height: 44px;
    width: auto;
    max-width: 200px;
    margin: 0;
    border: 0;
    border-radius: 6px;
    box-shadow: none;
    background: white;
    object-fit: contain;
    padding: 4px 8px;
  }
  .doc-prose .doc-logo-row .doc-logo-meta {
    flex: 1;
    min-width: 0;
  }
  .doc-prose .doc-logo-row .doc-logo-meta strong {
    display: block;
    font-family: "D-DIN Condensed", "Roboto Condensed", system-ui, sans-serif;
    text-transform: uppercase;
    font-size: 1.1rem;
    letter-spacing: 0.02em;
    color: #121621;
  }
  .doc-prose .doc-logo-row .doc-logo-meta span {
    display: block;
    font-size: 0.875rem;
    color: #6B7280;
    margin-top: 0.15rem;
  }
  .doc-prose .doc-hero-image {
    display: block;
    margin: 1rem auto 2rem;
    max-width: 480px;
    width: 100%;
    height: auto;
    border-radius: 16px;
    border: 1px solid #E2E8F0;
    box-shadow: 0 8px 30px hsla(212, 100%, 50%, 0.10);
  }
  .doc-prose table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 1.5rem 0;
    font-size: 0.95em;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 1px 2px hsla(228, 29%, 10%, 0.04);
  }
  .doc-prose th, .doc-prose td {
    border-bottom: 1px solid #E2E8F0;
    padding: 0.7rem 1rem;
    text-align: left;
    vertical-align: top;
  }
  .doc-prose tr:last-child td { border-bottom: 0; }
  .doc-prose th {
    background: #F8FAFC;
    font-family: "Montserrat", system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.85em;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: #374151;
  }
  .doc-prose blockquote {
    border-left: 4px solid #0074FF;
    background: linear-gradient(135deg, #E8F2FF 0%, rgba(232, 242, 255, 0.5) 100%);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 12px 12px 0;
    color: #0052B3;
  }
  .doc-prose blockquote p { color: #002F66; margin: 0.35rem 0; }
  .doc-prose hr {
    border: 0;
    height: 1px;
    background: #E2E8F0;
    margin: 2.5rem 0;
  }
</style>
