---
import Layout from '../../layouts/Layout.astro';
import DocSidebar from '../../components/DocSidebar.astro';
import { fetchCategories, fetchPublishedPages, type DocCategory, type DocPage } from '../../lib/supabase';
import { getIcon } from '../../lib/icons';
import { marked } from 'marked';

export async function getStaticPaths() {
  const [categories, pages] = await Promise.all([fetchCategories(), fetchPublishedPages()]);
  const catById = new Map(categories.map((c) => [c.id, c]));
  return pages
    .map((p) => {
      const cat = catById.get(p.category_id);
      if (!cat) return null;
      return {
        params: { category: cat.slug, page: p.slug },
        props: { category: cat, page: p, allCategories: categories, allPages: pages },
      };
    })
    .filter(Boolean);
}

interface Props {
  category: DocCategory;
  page: DocPage;
  allCategories: DocCategory[];
  allPages: DocPage[];
}

const { category, page, allCategories, allPages } = Astro.props;
const Icon = getIcon(category.icon);

const pagesByCategory = new Map<string, DocPage[]>();
for (const p of allPages) {
  if (!pagesByCategory.has(p.category_id)) pagesByCategory.set(p.category_id, []);
  pagesByCategory.get(p.category_id)!.push(p);
}

// reading time
const wordCount = (page.content ?? '').trim().split(/\s+/).length;
const readMinutes = Math.max(1, Math.ceil(wordCount / 220));

// first image as og:image fallback
const firstImage = (page.content ?? '').match(/!\[[^\]]*\]\(([^)]+)\)/);
const ogImage = firstImage?.[1] ?? 'https://docs.trainar.ai/og-default.png';

// render markdown
marked.setOptions({ gfm: true, breaks: false });
const html = await marked.parse(page.content ?? '');

const updatedDate = new Date(page.updated_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout
  title={`${page.title} — TrainAR Docs`}
  description={page.excerpt ?? `${page.title} — TrainAR documentation.`}
  canonicalPath={`/${category.slug}/${page.slug}`}
  ogImage={ogImage}
>
  <div class="mx-auto max-w-7xl flex">
    <DocSidebar
      categories={allCategories}
      pagesByCategory={pagesByCategory}
      activeCategorySlug={category.slug}
      activePageSlug={page.slug}
    />

    <div class="flex-1 px-4 sm:px-6 lg:px-10 py-10">
      <article class="max-w-3xl">
        <nav class="mb-4 flex items-center gap-2 text-sm text-slate-500">
          <a href="/" class="hover:text-slate-900 transition">Docs</a>
          <span class="text-slate-300">/</span>
          <a href={`/${category.slug}`} class="hover:text-slate-900 transition">{category.name}</a>
          <span class="text-slate-300">/</span>
          <span class="text-slate-900 truncate">{page.title}</span>
        </nav>

        <header class="mb-8">
          <div class="flex items-center gap-2 mb-3 text-sm text-slate-500">
            <Icon class="h-4 w-4 text-blue-600" />
            <a href={`/${category.slug}`} class="font-medium text-slate-700 hover:text-blue-700">{category.name}</a>
            <span class="text-slate-300">·</span>
            <span>Last updated {updatedDate}</span>
            <span class="text-slate-300">·</span>
            <span>{readMinutes} min read</span>
          </div>
          <h1 class="text-4xl font-bold tracking-tight text-slate-900">{page.title}</h1>
          {page.excerpt && <p class="mt-3 text-lg text-slate-600">{page.excerpt}</p>}
        </header>

        <div class="doc-prose" set:html={html} />

        <footer class="mt-12 pt-8 border-t border-slate-200">
          <a href={`/${category.slug}`} class="inline-flex items-center gap-2 text-sm text-slate-600 hover:text-blue-700 transition">
            ← Back to {category.name}
          </a>
        </footer>
      </article>
    </div>
  </div>
</Layout>

<style is:global>
  .doc-prose {
    color: rgb(30 41 59);
    line-height: 1.7;
    font-size: 16px;
  }
  .doc-prose h2 {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: rgb(15 23 42);
    line-height: 1.3;
    border-bottom: 1px solid rgb(226 232 240);
    padding-bottom: 0.5rem;
  }
  .doc-prose h3 {
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    font-size: 1.2rem;
    font-weight: 600;
    color: rgb(15 23 42);
  }
  .doc-prose h4 {
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: rgb(15 23 42);
  }
  .doc-prose p {
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .doc-prose ul, .doc-prose ol {
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
    padding-left: 1.5rem;
  }
  .doc-prose ul { list-style: disc; }
  .doc-prose ol { list-style: decimal; }
  .doc-prose li { margin-top: 0.25rem; }
  .doc-prose li > p { margin: 0.25rem 0; }
  .doc-prose strong { color: rgb(15 23 42); font-weight: 600; }
  .doc-prose a {
    color: rgb(37 99 235);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .doc-prose a:hover { color: rgb(29 78 216); }
  .doc-prose code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    background: rgb(241 245 249);
    color: rgb(190 18 60);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.875em;
  }
  .doc-prose pre {
    background: rgb(15 23 42);
    color: rgb(241 245 249);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.25rem 0;
    font-size: 0.875rem;
  }
  .doc-prose pre code {
    background: transparent;
    color: inherit;
    padding: 0;
  }
  .doc-prose img {
    border-radius: 8px;
    border: 1px solid rgb(226 232 240);
    margin: 1.5rem auto;
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.05);
    max-width: 100%;
    height: auto;
  }
  .doc-prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.95em;
  }
  .doc-prose th, .doc-prose td {
    border: 1px solid rgb(226 232 240);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .doc-prose th { background: rgb(248 250 252); font-weight: 600; }
  .doc-prose blockquote {
    border-left: 3px solid rgb(59 130 246);
    background: rgb(239 246 255);
    padding: 0.75rem 1rem;
    margin: 1.25rem 0;
    border-radius: 0 6px 6px 0;
    color: rgb(30 64 175);
  }
</style>
