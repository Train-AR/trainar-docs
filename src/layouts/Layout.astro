---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
}

const {
  title = 'TrainAR Documentation',
  description = 'Everything you need to know about using TrainAR — the AR training platform for trades teams.',
  canonicalPath = '/',
  ogImage = 'https://docs.trainar.ai/og-default.png',
} = Astro.props;

const siteUrl = 'https://docs.trainar.ai';
const canonical = `${siteUrl}${canonicalPath}`;
---

<!doctype html>
<html lang="en" class="bg-white text-slate-900">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50">
    <header class="border-b border-slate-200 bg-white sticky top-0 z-30">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight text-slate-900 hover:opacity-80 transition">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-gradient-to-br from-sky-500 to-blue-600 text-white text-sm">∞</span>
          <span class="text-base">
            Train<span class="font-extrabold">AR</span>
            <span class="ml-1.5 text-xs font-medium uppercase tracking-wider text-slate-500">Docs</span>
          </span>
        </a>

        <nav class="hidden md:flex items-center gap-6 text-sm text-slate-600">
          <a href="https://trainar.ai" class="hover:text-slate-900 transition">Home</a>
          <a href="https://academy.trainar.ai" class="hover:text-slate-900 transition">Academy</a>
          <a href="https://dashboard.trainar.ai" class="hover:text-slate-900 transition">Dashboard</a>
        </nav>

        <div class="flex items-center gap-3">
          <a href="https://dashboard.trainar.ai/auth/login" class="hidden sm:inline text-sm text-slate-600 hover:text-slate-900 transition">Sign in</a>
          <a href="https://dashboard.trainar.ai/auth/signup" class="inline-flex items-center rounded-md bg-blue-600 px-3.5 py-1.5 text-sm font-medium text-white shadow-sm hover:bg-blue-700 transition">
            Try TrainAR Free
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-slate-200 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 text-sm text-slate-500 flex flex-col sm:flex-row gap-4 sm:items-center sm:justify-between">
        <div>© 2026 TrainAR — AR training for trades teams.</div>
        <div class="flex items-center gap-5">
          <a href="https://trainar.ai" class="hover:text-slate-800 transition">trainar.ai</a>
          <a href="https://trainar.ai/privacy" class="hover:text-slate-800 transition">Privacy</a>
          <a href="https://trainar.ai/terms" class="hover:text-slate-800 transition">Terms</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  html {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }
</style>
